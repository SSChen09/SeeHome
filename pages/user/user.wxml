<nav-bar title="我的" themeClass="{{themeClass}}" accentClass="{{accentClass}}" />
<view class="container {{themeClass}} {{accentClass}}">
  <view class="card">
    <view class="title">👤 用户信息</view>
    <view class="row" style="align-items:center;">
      <view class="avatar" style="width:80rpx;height:80rpx;border-radius:50%;background:linear-gradient(135deg, #667eea 0%, #764ba2 100%);display:flex;align-items:center;justify-content:center;color:white;font-size:32rpx;">
        <text>{{profile.nickname ? profile.nickname.charAt(0) : 'U'}}</text>
      </view>
      <view style="margin-left:20rpx;flex:1;">
        <view style="font-size:32rpx;font-weight:bold;">{{profile.nickname || '未设置昵称'}}</view>
        <view style="font-size:24rpx;color:#666;margin-top:4rpx;">家庭安全守护者</view>
      </view>
    </view>
    <view class="row" style="margin-top: 20rpx;">
      <input placeholder="设置你的昵称" value="{{profile.nickname}}" bindinput="onNicknameInput" style="flex:1;border:1px solid #ddd;border-radius:12rpx;padding:16rpx;font-size:28rpx;" />
      <button class="btn primary" style="margin-left:12rpx;" bindtap="saveProfile">保存</button>
    </view>
    <view class="row" style="margin-top: 16rpx;justify-content:space-between;">
      <view>
        <view style="font-size:24rpx;color:#666;">版本</view>
        <view style="font-size:28rpx;font-weight:bold;">{{version}}</view>
      </view>
      <view>
        <view style="font-size:24rpx;color:#666;">使用天数</view>
        <view style="font-size:28rpx;font-weight:bold;">{{usageDays}}天</view>
      </view>
      <view>
        <view style="font-size:24rpx;color:#666;">预警次数</view>
        <view style="font-size:28rpx;font-weight:bold;">{{warningCount}}次</view>
      </view>
    </view>
  </view>
  <view class="card">
    <view class="title">设备管理</view>
    <view class="row" style="margin-bottom: 12rpx;">
      <input placeholder="设备名称" value="{{newDeviceName}}" bindinput="onDeviceNameInput" style="flex:1;border:1px solid #ddd;border-radius:8rpx;padding:12rpx;" />
      <button class="btn primary" style="margin-left:12rpx;" bindtap="addDevice">添加</button>
    </view>
    <view class="col">
      <block wx:for="{{devices}}" wx:key="id">
        <view class="row" style="margin-bottom: 8rpx;">
          <text>{{item.name}} · {{item.type}}</text>
          <text style="color:#888;">#{{item.id}}</text>
        </view>
      </block>
      <block wx:if="{{devices.length === 0}}">
        <text>暂无设备</text>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="title">定位与城市</view>
    <view class="row">
      <text>自动定位</text>
      <switch checked="{{cityPref.auto}}" bindchange="onAutoLocateChange" />
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <input placeholder="城市（如：北京）" value="{{cityPref.city}}" bindinput="onCityInput" style="flex:1;border:1px solid #ddd;border-radius:8rpx;padding:12rpx;" />
      <button class="btn warning" style="margin-left:12rpx;" bindtap="saveCityPref">保存</button>
    </view>
    <view class="subtitle" style="margin-top: 16rpx;">收藏城市</view>
    <view class="row" style="margin-top: 12rpx;">
      <input placeholder="城市（如：上海）" value="{{newFavCity}}" bindinput="onFavCityInput" style="flex:1;border:1px solid #ddd;border-radius:8rpx;padding:12rpx;" />
      <button class="btn primary btn-sm" style="margin-left:12rpx;" bindtap="addFavCity">添加</button>
    </view>
    <scroll-view scroll-x="true" style="white-space:nowrap;margin-top:12rpx;">
      <block wx:for="{{favorites}}" wx:key="*this">
        <view class="chip" style="display:inline-flex;align-items:center;">
          <text>{{item}}</text>
          <text data-city="{{item}}" bindtap="removeFavCity" style="margin-left:8rpx;color:#e53935;">✕</text>
        </view>
      </block>
    </scroll-view>
  </view>

  <view class="card">
    <view class="title">主题设置</view>
    <view class="row">
      <text>主题</text>
      <picker mode="selector" range="{{themes}}" value="{{themeIndex}}" bindchange="onThemeChange">
        <view class="badge warning">{{themeLabel}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>主色</text>
      <picker mode="selector" range="{{accents}}" value="{{accentIndex}}" bindchange="onAccentChange">
        <view class="badge warning">{{accentLabel}}</view>
      </picker>
    </view>
  </view>

  <view class="card">
    <view class="title">历史记录</view>
    <view class="col">
      <block wx:for="{{history}}" wx:key="time">
        <view class="row" style="margin-bottom: 8rpx;">
          <text>{{formatTime(item.time)}}</text>
          <text>{{item.type}} · {{item.detail}}</text>
        </view>
      </block>
      <block wx:if="{{history.length === 0}}">
        <text>暂无记录</text>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="title">提醒设置</view>
    <view class="row">
      <text>方式</text>
      <picker mode="selector" range="{{methods}}" value="{{methodIndex}}" bindchange="onMethodChange">
        <view class="badge warning">{{notify.method}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>阈值等级</text>
      <picker mode="selector" range="{{levels}}" value="{{levelIndex}}" bindchange="onLevelChange">
        <view class="badge warning">{{notify.level}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>暴雨提醒阈值</text>
      <picker mode="selector" range="{{levels}}" value="{{thresholdIndices.rain}}" bindchange="onRainThresholdChange">
        <view class="badge warning">{{levels[thresholdIndices.rain]}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>台风提醒阈值</text>
      <picker mode="selector" range="{{levels}}" value="{{thresholdIndices.typhoon}}" bindchange="onTyphoonThresholdChange">
        <view class="badge warning">{{levels[thresholdIndices.typhoon]}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>洪水提醒阈值</text>
      <picker mode="selector" range="{{levels}}" value="{{thresholdIndices.flood}}" bindchange="onFloodThresholdChange">
        <view class="badge warning">{{levels[thresholdIndices.flood]}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>免打扰开始</text>
      <picker mode="time" value="{{quietStart}}" bindchange="onQuietStartChange">
        <view class="badge warning">{{quietStart}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <text>免打扰结束</text>
      <picker mode="time" value="{{quietEnd}}" bindchange="onQuietEndChange">
        <view class="badge warning">{{quietEnd}}</view>
      </picker>
    </view>
  </view>
</view>
