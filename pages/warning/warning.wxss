.risk-row {
  margin-top: 12rpx;
}
.hour-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 160rpx;
  margin-right: 12rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.hour {
  font-size: 28rpx;
  color: #333;
}
