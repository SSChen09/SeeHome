page {
  background-color: #f5f7fa;
}
.container {
  padding: 16rpx 24rpx;
}
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.title {
  font-size: 32rpx;
  color: #222;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #666;
}
.primary {
  background-color: #1e88e5;
  color: #fff;
}
.danger {
  background-color: #e53935;
  color: #fff;
}
.success {
  background-color: #43a047;
  color: #fff;
}
.warning {
  background-color: #fbc02d;
  color: #222;
}
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.col {
  display: flex;
  flex-direction: column;
}
.badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.btn {
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.hero {
  /* override in page */
}
