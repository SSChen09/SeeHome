page {
  background-color: #f5f7fa;
}
.container {
  padding: 16rpx 24rpx;
}
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.title {
  font-size: 32rpx;
  color: #222;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #666;
}
.primary {
  background-color: #1e88e5;
  color: #fff;
}
.danger {
  background-color: #e53935;
  color: #fff;
}
.success {
  background-color: #43a047;
  color: #fff;
}
.warning {
  background-color: #fbc02d;
  color: #222;
}
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.col {
  display: flex;
  flex-direction: column;
}
.badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.btn {
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}
.btn-sm {
  padding: 10rpx 16rpx;
  font-size: 24rpx;
}

.hero {
  /* override in page */
}

.theme-dark page {
  background-color: #0f1114;
}
.theme-dark .card {
  background-color: #14171a;
  color: #eaeef4;
  box-shadow: none;
}
.container {
  padding-bottom: 140rpx;
}
.theme-dark .title {
  color: #eaeef4;
}
.chip {
  background-color: #eef3f8;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  margin-right: 8rpx;
  font-size: 24rpx;
}
.chips {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
}
.trend {
  display: flex;
  align-items: flex-end;
  height: 120rpx;
}
.trend .bar {
  width: 16rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  background-color: #7a7e83;
}
.trend .bar.success {
  background-color: #43a047;
}
.trend .bar.warning {
  background-color: #fbc02d;
}
.trend .bar.danger {
  background-color: #e53935;
}
.accent-blue .primary {
  background-color: #1e88e5;
  color: #fff;
}
.accent-amber .primary {
  background-color: #fb8c00;
  color: #fff;
}
.accent-green .primary {
  background-color: #43a047;
  color: #fff;
}
