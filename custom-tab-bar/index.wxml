<view class="tabbar {{themeClass}} {{accentClass}}">
  <block wx:for="{{list}}" wx:key="pagePath">
    <view class="item {{index === selected ? 'active' : ''}}" data-index="{{index}}" bindtap="switchTab">
      <text class="icon">{{item.icon}}</text>
      <text class="label">{{item.text}}</text>
    </view>
  </block>
</view>
